{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "V-01 / V-02 / V-21 / V-29 箱ひげ図（雛形）。Denebに渡すフィールド: category（OPERATION / MARKINFO_MARKNO / SHOTINFO_DIRECTIONなど比較軸）, valueX, valueY（RAW_DATA_X/YやCORRDATA_OFSETX/Yを集計しないで渡す）。X/Y成分をfoldで縦持ちにして並置する。行数が多い場合は必須フィルターで絞ってから描画する",
  "usermeta": {
    "deneb": { "build": "skeleton", "metaVersion": 1 },
    "note": "V-29で「全体/方向1/方向2」の3パネルにする場合は、DAX側でSHOTINFO_DIRECTIONを複製した「全体」行を用意するか、categoryに方向列を割り当てて全体パネルを別ビジュアルにする"
  },
  "data": { "name": "dataset" },
  "transform": [
    { "fold": [ "valueX", "valueY" ], "as": [ "component", "value" ] },
    { "calculate": "datum.component == 'valueX' ? 'X成分' : 'Y成分'", "as": "成分" }
  ],
  "mark": { "type": "boxplot", "extent": 1.5, "size": 18 },
  "encoding": {
    "x": { "field": "category", "type": "nominal", "title": null, "axis": { "labelAngle": 0 } },
    "xOffset": { "field": "成分" },
    "y": { "field": "value", "type": "quantitative", "title": "値（nm）" },
    "color": {
      "field": "成分",
      "type": "nominal",
      "scale": { "range": [ "#1E2761", "#F96167" ] },
      "legend": { "title": null, "orient": "top" }
    },
    "tooltip": [
      { "field": "category", "title": "区分" },
      { "field": "成分", "title": "成分" }
    ]
  },
  "width": "container",
  "height": "container",
  "config": { "view": { "stroke": null } }
}
