{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "V-18 補正前Shot配列 俯瞰（Nikon）。CORRDATAの平均から補正前の格子を逆算、装置×OPERATION小マルチ",
  "usermeta": {
    "deneb": {
      "build": "per-visual",
      "metaVersion": 2
    },
    "datasetFields": [
      "EQPID",
      "OPERATION",
      "CORRDATA_POSX",
      "CORRDATA_POSY",
      "補正量X 平均",
      "補正量Y 平均",
      "CORR SCALX 平均",
      "CORR SCALY 平均",
      "CORR ROTX 平均",
      "CORR ROTY 平均"
    ],
    "note": "CORRDATA_POSはmm。Shotピッチ(枠)はOPERATIONから自動判定。符号規約はI-009"
  },
  "data": {
    "name": "dataset"
  },
  "params": [
    {
      "name": "exaggerate",
      "value": 40000,
      "bind": {
        "input": "range",
        "min": 1000,
        "max": 200000,
        "step": 1000,
        "name": "誇張倍率: "
      }
    }
  ],
  "transform": [
    {
      "calculate": "datum['CORRDATA_POSX']",
      "as": "shotXmm"
    },
    {
      "calculate": "datum['CORRDATA_POSY']",
      "as": "shotYmm"
    }
  ],
  "facet": {
    "row": {
      "field": "EQPID",
      "type": "nominal",
      "header": {
        "title": null
      }
    },
    "column": {
      "field": "OPERATION",
      "type": "nominal",
      "header": {
        "title": null
      }
    }
  },
  "spec": {
    "transform": [
      {
        "calculate": "datum.OPERATION === 'MSR-MLF' ? 22 : 24",
        "as": "pitchXmm"
      },
      {
        "calculate": "datum.OPERATION === 'MSR-MLF' ? 26 : 28",
        "as": "pitchYmm"
      },
      {
        "calculate": "[[-1,-1,0],[1,-1,1],[1,1,2],[-1,1,3],[-1,-1,4]]",
        "as": "corners"
      },
      {
        "flatten": [
          "corners"
        ]
      },
      {
        "calculate": "datum.corners[0] * datum.pitchXmm / 2",
        "as": "rxMm"
      },
      {
        "calculate": "datum.corners[1] * datum.pitchYmm / 2",
        "as": "ryMm"
      },
      {
        "calculate": "datum.corners[2]",
        "as": "cornerOrder"
      },
      {
        "calculate": "datum['補正量X 平均'] + datum['CORR SCALX 平均'] * datum.rxMm - datum['CORR ROTX 平均'] * datum.ryMm",
        "as": "dxNm"
      },
      {
        "calculate": "datum['補正量Y 平均'] + datum['CORR SCALY 平均'] * datum.ryMm + datum['CORR ROTY 平均'] * datum.rxMm",
        "as": "dyNm"
      },
      {
        "calculate": "datum.shotXmm + datum.rxMm",
        "as": "nomX"
      },
      {
        "calculate": "datum.shotYmm + datum.ryMm",
        "as": "nomY"
      },
      {
        "calculate": "datum.nomX + datum.dxNm / 1000000 * exaggerate",
        "as": "preX"
      },
      {
        "calculate": "datum.nomY + datum.dyNm / 1000000 * exaggerate",
        "as": "preY"
      }
    ],
    "layer": [
      {
        "data": {
          "sequence": {
            "start": 0,
            "stop": 6.32,
            "step": 0.05,
            "as": "t"
          }
        },
        "transform": [
          {
            "calculate": "150 * cos(datum.t)",
            "as": "circleX"
          },
          {
            "calculate": "150 * sin(datum.t)",
            "as": "circleY"
          }
        ],
        "mark": {
          "type": "line",
          "stroke": "#9AA0B4",
          "strokeWidth": 1
        },
        "encoding": {
          "x": {
            "field": "circleX",
            "type": "quantitative",
            "scale": {
              "domain": [
                -165,
                165
              ]
            },
            "axis": null,
            "title": null
          },
          "y": {
            "field": "circleY",
            "type": "quantitative",
            "scale": {
              "domain": [
                -165,
                165
              ]
            },
            "axis": null,
            "title": null
          },
          "order": {
            "field": "t"
          }
        }
      },
      {
        "mark": {
          "type": "line",
          "stroke": "#C8CCDA",
          "strokeWidth": 0.6
        },
        "encoding": {
          "x": {
            "field": "nomX",
            "type": "quantitative",
            "scale": {
              "domain": [
                -165,
                165
              ]
            },
            "axis": null,
            "title": null
          },
          "y": {
            "field": "nomY",
            "type": "quantitative",
            "scale": {
              "domain": [
                -165,
                165
              ]
            },
            "axis": null,
            "title": null
          },
          "detail": [
            {
              "field": "CORRDATA_POSX"
            },
            {
              "field": "CORRDATA_POSY"
            }
          ],
          "order": {
            "field": "cornerOrder"
          }
        }
      },
      {
        "mark": {
          "type": "line",
          "stroke": "#F96167",
          "strokeWidth": 1.2
        },
        "encoding": {
          "x": {
            "field": "preX",
            "type": "quantitative",
            "scale": {
              "domain": [
                -165,
                165
              ]
            },
            "axis": null,
            "title": null
          },
          "y": {
            "field": "preY",
            "type": "quantitative",
            "scale": {
              "domain": [
                -165,
                165
              ]
            },
            "axis": null,
            "title": null
          },
          "detail": [
            {
              "field": "CORRDATA_POSX"
            },
            {
              "field": "CORRDATA_POSY"
            }
          ],
          "order": {
            "field": "cornerOrder"
          },
          "tooltip": [
            {
              "field": "shotXmm",
              "title": "Shot X (mm)",
              "format": ".1f"
            },
            {
              "field": "shotYmm",
              "title": "Shot Y (mm)",
              "format": ".1f"
            },
            {
              "field": "dxNm",
              "title": "変位X (nm)",
              "format": ".1f"
            },
            {
              "field": "dyNm",
              "title": "変位Y (nm)",
              "format": ".1f"
            }
          ]
        }
      }
    ],
    "width": 220,
    "height": 220
  },
  "config": {
    "view": {
      "stroke": null
    }
  }
}
