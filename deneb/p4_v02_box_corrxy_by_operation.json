{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "V-02 補正量X/Yの箱ひげ図（OPERATION別、X成分/Y成分の2面）",
  "usermeta": {
    "deneb": {
      "build": "per-visual",
      "metaVersion": 2
    },
    "datasetFields": [
      "OPERATION",
      "WAFER_ID",
      "CORRDATA_ID",
      "補正量X 平均",
      "補正量Y 平均"
    ],
    "note": "左=X成分、右=Y成分。WAFER_ID/CORRDATA_IDは補正点単位の行を得るためのキー"
  },
  "data": {
    "name": "dataset"
  },
  "hconcat": [
    {
      "title": "X成分",
      "mark": {
        "type": "boxplot",
        "extent": 1.5,
        "size": 18
      },
      "encoding": {
        "x": {
          "field": "OPERATION",
          "type": "nominal",
          "title": null,
          "axis": {
            "labelAngle": 0
          }
        },
        "y": {
          "field": "補正量X 平均",
          "type": "quantitative",
          "title": "X成分 (nm)"
        },
        "color": {
          "value": "#1E2761"
        }
      },
      "width": 150,
      "height": 140
    },
    {
      "title": "Y成分",
      "mark": {
        "type": "boxplot",
        "extent": 1.5,
        "size": 18
      },
      "encoding": {
        "x": {
          "field": "OPERATION",
          "type": "nominal",
          "title": null,
          "axis": {
            "labelAngle": 0
          }
        },
        "y": {
          "field": "補正量Y 平均",
          "type": "quantitative",
          "title": "Y成分 (nm)"
        },
        "color": {
          "value": "#F96167"
        }
      },
      "width": 150,
      "height": 140
    }
  ],
  "resolve": {
    "scale": {
      "y": "shared"
    }
  },
  "config": {
    "view": {
      "stroke": null
    }
  }
}
