	partition NIKON = m
		mode: import
		source =
				let
				    Source = Csv.Document(
				        File.Contents(SampleDataFolder & "V_EQP_WAFER_LITHOBOOSTER_NIKON_sample.csv"),
				        [Delimiter = ",", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]),
				    Headers = Table.PromoteHeaders(Source, [PromoteAllScalars = true]),
				    Typed = Table.TransformColumnTypes(Headers, {{"TEC_KIND", type text}, {"LOT_ID", type text}, {"WAFER_ID", type text}, {"WAFER_NO", Int64.Type}, {"CREATE_TIME", type datetime}, {"MEASUREMENT_TIME", type datetime}, {"PROCESS", type text}, {"OPERATION", type text}, {"PRODUCT", type text}, {"EQPID", type text}, {"DEVICE_TYPE", type text}, {"CTRL_JOB", type text}, {"WAFER_OFSETX", type number}, {"WAFER_OFSETY", type number}, {"WAFER_SCALX", type number}, {"WAFER_SCALY", type number}, {"WAFER_ROTX", type number}, {"WAFER_ROTY", type number}, {"SHOT_OFSETX", type number}, {"SHOT_OFSETY", type number}, {"SHOT_SCALX", type number}, {"SHOT_SCALY", type number}, {"SHOT_ROTX", type number}, {"SHOT_ROTY", type number}, {"CORRDATA_ID", Int64.Type}, {"CORRDATA_POSX", type number}, {"CORRDATA_POSY", type number}, {"CORRDATA_OFSETX", type number}, {"CORRDATA_OFSETY", type number}, {"CORRDATA_SCALX", type number}, {"CORRDATA_SCALY", type number}, {"CORRDATA_ROTX", type number}, {"CORRDATA_ROTY", type number}, {"SHOTFAC02X", type number}, {"SHOTFAC03X", type number}, {"SHOTFAC04X", type number}, {"SHOTFAC05X", type number}, {"SHOTFAC06X", type number}, {"SHOTFAC11Y", type number}, {"SHOTFAC02Y", type number}, {"SHOTFAC12Y", type number}, {"SHOTFAC03Y", type number}, {"SHOTFAC13Y", type number}, {"SHOTFAC04Y", type number}, {"SHOTFAC14Y", type number}, {"SHOTFAC05Y", type number}, {"SHOTFAC15Y", type number}, {"SHOTFAC06Y", type number}, {"SHOTFAC20X", type number}, {"SHOTFAC20Y", type number}, {"SHOTFAC30X", type number}, {"SHOTFAC11X", type number}, {"SHOTFAC12X", type number}, {"SHOTFAC21Y", type number}, {"ST_TIMESTAMP", type datetime}}, "en-US"),
				    // 日付テーブルとのリレーション用に計測日（日付型）を追加する
				    AddMeasureDate = Table.AddColumn(Typed, "計測日", each Date.From([MEASUREMENT_TIME]), type date)
				in
				    AddMeasureDate
