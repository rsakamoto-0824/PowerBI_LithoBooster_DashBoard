table CANON

	/// 選択範囲の計測値Xの平均（nm）
	measure '計測値X 平均' = AVERAGE ( 'CANON'[RAW_DATA_X] )
		formatString: 0.00

	measure '計測値Y 平均' = AVERAGE ( 'CANON'[RAW_DATA_Y] )
		formatString: 0.00

	measure '計測値X 3σ' = 3 * STDEV.P ( 'CANON'[RAW_DATA_X] )
		formatString: 0.00

	measure '計測値Y 3σ' = 3 * STDEV.P ( 'CANON'[RAW_DATA_Y] )
		formatString: 0.00

	/// KPIカード用の「平均 ± 3σ」表示文字列（nm）
	measure '計測値X 平均±3σ 表示' =
			VAR AvgX = [計測値X 平均]
			VAR Sigma3X = [計測値X 3σ]
			RETURN
				FORMAT ( AvgX, "0.0" ) & " ± " & FORMAT ( Sigma3X, "0.0" ) & " nm"

	measure '計測値Y 平均±3σ 表示' =
			VAR AvgY = [計測値Y 平均]
			VAR Sigma3Y = [計測値Y 3σ]
			RETURN
				FORMAT ( AvgY, "0.0" ) & " ± " & FORMAT ( Sigma3Y, "0.0" ) & " nm"

	measure '計測値X RMS' =
			VAR SumSq = SUMX ( 'CANON', 'CANON'[RAW_DATA_X] * 'CANON'[RAW_DATA_X] )
			VAR Points = COUNTROWS ( 'CANON' )
			RETURN
				SQRT ( DIVIDE ( SumSq, Points ) )
		formatString: 0.00

	measure '計測値Y RMS' =
			VAR SumSq = SUMX ( 'CANON', 'CANON'[RAW_DATA_Y] * 'CANON'[RAW_DATA_Y] )
			VAR Points = COUNTROWS ( 'CANON' )
			RETURN
				SQRT ( DIVIDE ( SumSq, Points ) )
		formatString: 0.00

	/// 計測値ベクトル長 √(X²+Y²) の平均（nm）
	measure 'ベクトル長 平均' =
			AVERAGEX (
				'CANON',
				SQRT (
					'CANON'[RAW_DATA_X] * 'CANON'[RAW_DATA_X]
						+ 'CANON'[RAW_DATA_Y] * 'CANON'[RAW_DATA_Y]
				)
			)
		formatString: 0.00

	measure 'Wafer数' = DISTINCTCOUNT ( 'CANON'[WAFER_ID] )
		formatString: 0

	measure 'Lot数' = DISTINCTCOUNT ( 'CANON'[LOT_ID] )
		formatString: 0

	measure '測定点数' = COUNTROWS ( 'CANON' )
		formatString: #,0

	/// 判定=0の測定点の割合（0/1の意味はI-002で確認中）
	measure '判定0率X' =
			VAR ZeroPoints =
				CALCULATE ( COUNTROWS ( 'CANON' ), 'CANON'[RAW_DATA_STSX] = 0 )
			VAR AllPoints = COUNTROWS ( 'CANON' )
			RETURN
				DIVIDE ( ZeroPoints, AllPoints )
		formatString: 0.0%

	/// 共分散楕円用（V-22/V-23）。分散・共分散はDeneb側で E[X²]−E[X]² / E[XY]−E[X]E[Y] から計算する
	measure '計測値X2乗 平均' = AVERAGEX ( 'CANON', 'CANON'[RAW_DATA_X] * 'CANON'[RAW_DATA_X] )
		formatString: 0.00

	measure '計測値Y2乗 平均' = AVERAGEX ( 'CANON', 'CANON'[RAW_DATA_Y] * 'CANON'[RAW_DATA_Y] )
		formatString: 0.00

	measure '計測値XY 平均' = AVERAGEX ( 'CANON', 'CANON'[RAW_DATA_X] * 'CANON'[RAW_DATA_Y] )
		formatString: 0.00

	/// Wafer低次補正成分トレンド用（V-06）。単位は想定: シフトnm
	measure 'AGA SX 平均' = AVERAGE ( 'CANON'[AGA_LINEAR_SX] )
		formatString: 0.00

	measure 'AGA SY 平均' = AVERAGE ( 'CANON'[AGA_LINEAR_SY] )
		formatString: 0.00

	/// 単位は想定: 倍率ppm
	measure 'AGA MX 平均' = AVERAGE ( 'CANON'[AGA_LINEAR_MX] )
		formatString: 0.00

	measure 'AGA MY 平均' = AVERAGE ( 'CANON'[AGA_LINEAR_MY] )
		formatString: 0.00

	/// 単位は想定: 回転µrad
	measure 'AGA TX 平均' = AVERAGE ( 'CANON'[AGA_LINEAR_TX] )
		formatString: 0.00

	measure 'AGA TY 平均' = AVERAGE ( 'CANON'[AGA_LINEAR_TY] )
		formatString: 0.00

	/// Shotごとの線形補正値プロット用（V-03、SEPA=Scanner用）
	measure 'SEPA SMAGX 平均' = AVERAGE ( 'CANON'[SEPA_SHOTFORM_SMAGX] )
		formatString: 0.00

	measure 'SEPA SMAGY 平均' = AVERAGE ( 'CANON'[SEPA_SHOTFORM_SMAGY] )
		formatString: 0.00

	measure 'SEPA SROTX 平均' = AVERAGE ( 'CANON'[SEPA_SHOTFORM_SROTX] )
		formatString: 0.00

	measure 'SEPA SROTY 平均' = AVERAGE ( 'CANON'[SEPA_SHOTFORM_SROTY] )
		formatString: 0.00

	measure 'SEPA SHIFTX 平均' = AVERAGE ( 'CANON'[SEPA_SHOTDATA_SHIFTX] )
		formatString: 0.00

	measure 'SEPA SHIFTY 平均' = AVERAGE ( 'CANON'[SEPA_SHOTDATA_SHIFTY] )
		formatString: 0.00

	/// Shotごとの線形補正値プロット用（V-03、SAME=Stepper用）
	measure 'SAME SMAGX 平均' = AVERAGE ( 'CANON'[SAME_SHOTFORM_SMAGX] )
		formatString: 0.00

	measure 'SAME SMAGY 平均' = AVERAGE ( 'CANON'[SAME_SHOTFORM_SMAGY] )
		formatString: 0.00

	measure 'SAME SROTX 平均' = AVERAGE ( 'CANON'[SAME_SHOTFORM_SROTX] )
		formatString: 0.00

	measure 'SAME SROTY 平均' = AVERAGE ( 'CANON'[SAME_SHOTFORM_SROTY] )
		formatString: 0.00

	measure 'SAME SHIFTX 平均' = AVERAGE ( 'CANON'[SAME_SHOTDATA_SHIFTX] )
		formatString: 0.00

	measure 'SAME SHIFTY 平均' = AVERAGE ( 'CANON'[SAME_SHOTDATA_SHIFTY] )
		formatString: 0.00

