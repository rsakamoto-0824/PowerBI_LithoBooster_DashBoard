	partition CANON = m
		mode: import
		source =
				let
				    Source = Csv.Document(
				        File.Contents(SampleDataFolder & "V_EQP_WAFER_LITHOBOOSTER_CANON_sample.csv"),
				        [Delimiter = ",", Encoding = 65001, QuoteStyle = QuoteStyle.Csv]),
				    Headers = Table.PromoteHeaders(Source, [PromoteAllScalars = true]),
				    Typed = Table.TransformColumnTypes(Headers, {{"TEC_KIND", type text}, {"LOT_ID", type text}, {"WAFER_ID", type text}, {"WAFER_NO", Int64.Type}, {"CREATE_TIME", type datetime}, {"MEASUREMENT_TIME", type datetime}, {"PROCESS", type text}, {"OPERATION", type text}, {"PRODUCT", type text}, {"EQPID", type text}, {"DEVICE_TYPE", type text}, {"CTRL_JOB", type text}, {"SHOTINFO_SHOTNO", Int64.Type}, {"SHOTINFO_PosX", Int64.Type}, {"SHOTINFO_PosY", Int64.Type}, {"SHOTINFO_DIRECTION", Int64.Type}, {"IS_AGA_SAMPLE_SHOTS", type logical}, {"MARKINFO_MARKNO", Int64.Type}, {"MARKINFO_POSX", type number}, {"MARKINFO_POSY", type number}, {"AGA_LINEAR_MX", type number}, {"AGA_LINEAR_MY", type number}, {"AGA_LINEAR_TX", type number}, {"AGA_LINEAR_TY", type number}, {"AGA_LINEAR_SX", type number}, {"AGA_LINEAR_SY", type number}, {"AGA_SHOT_MX", type number}, {"AGA_SHOT_MY", type number}, {"AGA_SHOT_TX", type number}, {"AGA_SHOT_TY", type number}, {"PSO_LINEAR_MX", type number}, {"PSO_LINEAR_MY", type number}, {"PSO_LINEAR_TX", type number}, {"PSO_LINEAR_TY", type number}, {"PSO_LINEAR_SX", type number}, {"PSO_LINEAR_SY", type number}, {"PSO_LINEAR_3SX", type number}, {"PSO_LINEAR_3SY", type number}, {"SEPA_SHOTFORM_SMAGX", type number}, {"SEPA_SHOTFORM_SMAGY", type number}, {"SEPA_SHOTFORM_SROTX", type number}, {"SEPA_SHOTFORM_SROTY", type number}, {"SEPA_SHOTDATA_SHIFTX", type number}, {"SEPA_SHOTDATA_SHIFTY", type number}, {"SAME_SHOTFORM_SMAGX", type number}, {"SAME_SHOTFORM_SMAGY", type number}, {"SAME_SHOTFORM_SROTX", type number}, {"SAME_SHOTFORM_SROTY", type number}, {"SAME_SHOTDATA_SHIFTX", type number}, {"SAME_SHOTDATA_SHIFTY", type number}, {"RAW_DATA_X", type number}, {"RAW_DATA_Y", type number}, {"RAW_DATA_STSX", type number}, {"RAW_DATA_STSY", type number}, {"ST_TIMESTAMP", type datetime}}, "en-US"),
				    // 日付テーブルとのリレーション用に計測日（日付型）を追加する
				    AddMeasureDate = Table.AddColumn(Typed, "計測日", each Date.From([MEASUREMENT_TIME]), type date)
				in
				    AddMeasureDate
